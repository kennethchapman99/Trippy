+  const start = addDaysToIso(tripStart, startDay - 1);
+  const end = addDaysToIso(tripStart, endDay - 1);
+  return `${formatIsoShortDate(start)}${end && end !== start ? ` - ${formatIsoShortDate(end)}` : ""}`;
+}
