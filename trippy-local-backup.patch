+        "and",
+        "base",
+        "side",
+        "coast",
+        "area",
+        "near",
+        "central",
+        "north",
+        "south",
+        "east",
+        "west",
+        "sao",
+        "são",
+        "miguel",
+    }
+    return {
+        token
+        for token in re.split(r"[^a-z0-9]+", region.lower())
+        if len(token) >= 4 and token not in stopwords
+    }
+
+
