+                    "query": f"{destination} family food culture experience",
+                },
+            ]
+        )
+    deduped: list[dict[str, str]] = []
+    seen: set[str] = set()
+    for target in targets:
+        key = target["query"].lower()
+        if key not in seen:
+            seen.add(key)
