# Copy to .env and fill in values — never commit .env
ANTHROPIC_API_KEY=sk-ant-...

# LLM routing / latency controls
TRIPPY_LLM_MODE=advisory
TRIPPY_PLANNING_LLM_MODE=advisory
TRIPPY_LLM_MODEL_FAST=claude-sonnet-4-6
TRIPPY_LLM_MODEL_DEEP=claude-opus-4-7
TRIPPY_LLM_MODEL_CHEAP=claude-haiku-4-5
TRIPPY_AGENT_LLM_MODEL=claude-sonnet-4-6
TRIPPY_TRIP_IDEATION_MODEL=claude-sonnet-4-6
TRIPPY_TRIP_IDEATION_DEEP_MODEL=claude-opus-4-7
TRIPPY_TRIP_PLANNER_MODEL=claude-sonnet-4-6
TRIPPY_TRIP_PLANNER_DEEP_MODEL=claude-opus-4-7
TRIPPY_PLANNING_ADVISOR_MODEL=claude-sonnet-4-6
TRIPPY_PLANNING_ADVISOR_DEEP_MODEL=claude-opus-4-7
TRIPPY_GEOGRAPHY_RESOLVER_MODEL=claude-sonnet-4-6
TRIPPY_CONFIRMATION_PARSER_MODEL=claude-sonnet-4-6
TRIPPY_SOURCE_RESEARCH_EXTRACTOR_MODEL=claude-sonnet-4-6
TRIPPY_FRICTION_LLM_MODEL=claude-haiku-4-5
TRIPPY_PLANNING_LLM_ENABLED=true
TRIPPY_IDEATION_LLM_ENABLED=true
TRIPPY_TRIP_PLANNER_LLM_ENABLED=true
TRIPPY_LODGING_LLM_ENABLED=true
TRIPPY_GEOGRAPHY_LLM_ENABLED=true
TRIPPY_SOURCE_RESEARCH_LLM_ENABLED=true
TRIPPY_FRICTION_LLM_ENABLED=false
TRIPPY_FAST_IDEATION_ENABLED=true
TRIPPY_DEEP_IDEATION_ON_SELECTION=true
TRIPPY_LLM_CACHE_ENABLED=true
TRIPPY_LLM_CACHE_TTL_SECONDS=86400
TRIPPY_LLM_ACCOUNTING_ENABLED=true

TRIPPY_DB_PATH=~/.trippy/state.db
TRIPPY_MEMORY_PATH=~/.trippy/memory.json
TRIPPY_TRIPS_PATH=~/.trippy/trips
TRIPPY_INTAKES_PATH=~/.trippy/intakes
TRIPPY_PLANS_PATH=~/.trippy/plans
TRIPPY_WORKSPACES_PATH=~/.trippy/workspaces
TRIPPY_SHORTLISTS_PATH=~/.trippy/shortlists
TRIPPY_RESEARCH_PATH=~/.trippy/research
TRIPPY_VAULT_PATH=~/.trippy/vault
TRIPPY_EXPORT_PATH=~/.trippy/export
TRIPPY_LEARNING_PATH=~/.trippy/learning
TRIPPY_LLM_CACHE_PATH=~/.trippy/llm_cache
TRIPPY_LLM_ACCOUNTING_PATH=~/.trippy/llm_accounting
TRIPPY_LIVE_VALIDATION_ENABLED=false
TRIPPY_LIVE_VALIDATION_TIMEOUT_SECONDS=4
TRIPPY_SOURCE_RESEARCH_TIMEOUT_SECONDS=12
TRIPPY_SOURCE_RESEARCH_PLAYWRIGHT_ENABLED=false
TRIPPY_SOURCE_RESEARCH_OPENCLAW_ENABLED=false
TRIPPY_OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
TRIPPY_OPENCLAW_COMMAND=openclaw
TRIPPY_OPENCLAW_AGENT_ID=main
TRIPPY_TELEGRAM_BOT_TOKEN=
TRIPPY_TELEGRAM_ALLOWED_CHAT_IDS=
TRIPPY_TELEGRAM_POLL_TIMEOUT_SECONDS=25
TRIPPY_TELEGRAM_REPLY_CHUNK_SIZE=3500
GMAIL_CREDENTIALS_PATH=~/.trippy/gmail_credentials.json
GOOGLE_TOKEN_PATH=~/.trippy/google_token.json
TRIPPY_SHEET_TEMPLATE_ID=
SHERPA_API_KEY=
DUFFEL_ACCESS_TOKEN=
SERPAPI_KEY=
TRIPPY_SERPAPI_TIMEOUT_SECONDS=12
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=https://api.firecrawl.dev
FIRECRAWL_ENABLED=true
FIRECRAWL_CACHE_TTL_SECONDS=900
FIRECRAWL_MAX_RESULTS=5
GOOGLE_SHEETS_API_KEY=
